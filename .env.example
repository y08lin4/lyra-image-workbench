# 服务监听地址。绑定域名 + Nginx/宝塔反代时建议保持 127.0.0.1。
LOCAL_IMAGE_HOST=127.0.0.1
LOCAL_IMAGE_PORT=8787

# 运行时数据目录。会保存用户、任务、空间配置和本机 Key 状态。
LOCAL_IMAGE_DATA_DIR=data

# 前端构建产物目录。生产环境先运行：cd web && npm ci && npm run build
LOCAL_IMAGE_WEB_DIR=web/dist

# 首次设置 /admin 管理密码必须填写的安装令牌；请部署前生成随机值。
LOCAL_IMAGE_ADMIN_SETUP_TOKEN=change-me-random-install-token

# NewAPI / OpenAI 兼容网关地址。
NEWAPI_BASE_URL=http://127.0.0.1:3000/v1

# 单张图片请求超时秒数，允许范围 60-3600。
NEWAPI_TIMEOUT_SEC=600
